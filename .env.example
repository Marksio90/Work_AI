APP_NAME=work-ai
ENV_PROFILE=dev
LOG_LEVEL=INFO

API_HOST=0.0.0.0
API_PORT=8000

DATABASE_URL=sqlite+pysqlite:///./work_ai.db
REDIS_URL=redis://localhost:6379/0

CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
CELERY_TASK_SOFT_TIME_LIMIT=90
CELERY_TASK_TIME_LIMIT=120

IDEMPOTENCY_TTL_SECONDS=86400
DEDUP_TTL_SECONDS=3600

PROVIDER_NAME=mock
PROVIDER_MODEL=mock-model

TASK_SOURCE_NAME=mock_marketplace
TASK_SOURCE_POLL_BATCH_SIZE=10
TASK_SOURCE_POLL_INTERVAL_SECONDS=30

ECONOMICS_MIN_MARGIN_USD=0.005
ECONOMICS_DEFAULT_SUCCESS_PROBABILITY=0.85
ECONOMICS_INFRA_COST_PER_TASK_USD=0.002
ECONOMICS_TOKEN_COST_PER_1K_USD=0.0015
TASK_SOURCE_MODE=mock_pull
RAPIDAPI_PROXY_SECRET=changeme-rapidapi-secret
RAPIDAPI_PRICE_FREE_USD=0.0
RAPIDAPI_PRICE_BASIC_USD=0.03
RAPIDAPI_PRICE_PRO_USD=0.06
